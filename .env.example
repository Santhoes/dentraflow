# Copy to .env.local and fill values. Do not commit .env.local.

# Supabase (from project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App (production: https://dentraflow.com — for local dev use http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://dentraflow.com

# PayPal (Settings > Billing). Live API only.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Webhook: create a webhook in PayPal Developer Dashboard pointing to https://your-domain.com/api/paypal/webhook, subscribe to PAYMENT.CAPTURE.COMPLETED and PAYMENT.CAPTURE.DENIED, then set the Webhook ID here.
PAYPAL_WEBHOOK_ID=

# Resend API: all email in the app (appointments, reminders, plan expiry, clinic notifications).
# Sign up at resend.com, add domain, then create API key.
RESEND_API_KEY=
RESEND_FROM=DentraFlow <ai@dentraflow.com>
RESEND_FROM_EMAIL=DentraFlow <onboarding@resend.dev>

# Contact form: where to receive messages from the public contact page.
CONTACT_EMAIL=support@dentraflow.com

# Chat widget: secret to sign embed URLs so slugs can't be guessed. Set a long random string.
CHAT_PROTECTION_SECRET=

# Production AI chat (embed widget). Get key from platform.openai.com.
OPENAI_API_KEY=

# Cron: secret for securing /api/cron/renewal-reminders (e.g. Vercel Cron or external scheduler).
CRON_SECRET=

# Optional: comma-separated admin emails for /admin. If unset, only admin@dentraflow.com is admin.
# ADMIN_EMAILS=admin@dentraflow.com,other@example.com
